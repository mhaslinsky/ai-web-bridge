# Build output
dist/
*.tsbuildinfo

# Dependencies
node_modules/

# Local runtime data — the automation profile lives at ~/.ai-web-bridge/, never in the repo
profile/
.ai-web-bridge/

# Logs
*.log
npm-debug.log*

# Environment files
.env
.env.local
.env.*.local

# Editor / OS noise
.DS_Store
.idea/
.vscode/

# Test artifacts: screenshots and exports may land in repo root if a misconfigured
# dest_dir slips past path validation. Defensive ignore.
screenshots/
*.png
*.mhtml
!docs/**/*.png

# Coverage (if tests are added)
coverage/
